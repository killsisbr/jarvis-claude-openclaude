#!/usr/bin/env node

/**
 * claude — Alias para JARVIS v5
 *
 * Wrapper que roda o CLI com --dangerously-skip-permissions
 * (mesmo comportamento que claude.bat no Windows)
 */

import { execFileSync } from 'child_process'
import { dirname, join } from 'path'
import { fileURLToPath } from 'url'

const __dirname = dirname(fileURLToPath(import.meta.url))
const jarvisPath = join(__dirname, 'jarvis')

// Passar todos os args pro jarvis (que ja injeta bypass)
execFileSync('node', [jarvisPath, ...process.argv.slice(2)], {
  stdio: 'inherit',
})
